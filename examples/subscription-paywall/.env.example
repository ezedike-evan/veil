# Copy to .env.local and fill in your values.
# Testnet defaults work out of the box — you only need to set a merchant address.

# Stellar network (testnet | mainnet)
NEXT_PUBLIC_NETWORK=testnet

# Factory contract address. Deploy one on testnet (see TESTNET_SETUP.md, Step 4)
# and paste its C… address here — required before "Create wallet" can deploy a
# wallet contract.
NEXT_PUBLIC_FACTORY_CONTRACT_ID=

# Soroban RPC endpoint
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon REST API endpoint
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# ── Subscription settings ────────────────────────────────────────────────────

# The merchant the subscription pays. "Unlock" authorizes this address (the
# spender) to pull up to the price from the wallet until the period expires.
# Use any Stellar address you control (G… classic account or C… contract).
NEXT_PUBLIC_MERCHANT_ADDRESS=

# Token the subscription is billed in. Leave blank to use native XLM (the SAC for
# the selected network), or set a token contract address (C…).
NEXT_PUBLIC_SUBSCRIPTION_TOKEN=

# Price per billing period, in whole token units (e.g. 5 = 5 XLM).
NEXT_PUBLIC_SUBSCRIPTION_PRICE=5

# Billing period length in days. The on-chain authorization expires after this.
NEXT_PUBLIC_SUBSCRIPTION_PERIOD_DAYS=30
