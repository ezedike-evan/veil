# Testnet defaults work out of the box — no edits needed to run the demo.
#
# These are read on the server (loader/action) via process.env and exposed to
# the client through the root loader (see app/lib/network.ts).
NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
# Deploy the Veil factory contract and paste its C... address here to enable
# wallet deployment. Registration/login work without it.
FACTORY_CONTRACT_ID=
