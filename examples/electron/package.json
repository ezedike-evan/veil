{
  "name": "veil-electron-example",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop wallet example using the Veil web SDK in the renderer process",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,yellow \"vite\" \"wait-on tcp:5174 && cross-env ELECTRON_RENDERER_URL=http://localhost:5174 electron .\"",
    "build": "tsc && vite build",
    "start": "npm run build && electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "invisible-wallet-sdk": "file:../../sdk",
    "@veil/invisible-wallet-sdk": "file:../../sdk",
    "@stellar/stellar-sdk": "^14.6.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.14.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "typescript": "^5.6.2",
    "vite": "^5.1.0",
    "wait-on": "^8.0.1"
  }
}
