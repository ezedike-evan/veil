# ── Client (public) ──────────────────────────────────────────────────────────
# Testnet defaults work out of the box — no edits needed to run the demo.
NUXT_PUBLIC_NETWORK=testnet
NUXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NUXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
# Deploy the Veil factory contract and paste its C... address here to enable
# wallet deployment. Registration/login work without it.
NUXT_PUBLIC_FACTORY_CONTRACT_ID=

# ── Server (private) ─────────────────────────────────────────────────────────
# Domain of the SEP-24 anchor whose interactive deposit/withdraw flow redirects
# back to /api/sep24/callback. Defaults to the Stellar reference test anchor.
ANCHOR_DOMAIN=testanchor.stellar.org
